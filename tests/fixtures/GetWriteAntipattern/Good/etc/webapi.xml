<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <route url="/V1/products/:sku" method="GET">
        <service class="Vendor\Module\Api\ProductRepositoryInterface" method="get"/>
        <resources>
            <resource ref="Vendor_Module::products"/>
        </resources>
    </route>
    <route url="/V1/products/:sku" method="POST">
        <service class="Vendor\Module\Api\ProductRepositoryInterface" method="save"/>
        <resources>
            <resource ref="Vendor_Module::products"/>
        </resources>
    </route>
    <route url="/V1/products/:sku" method="DELETE">
        <service class="Vendor\Module\Api\ProductRepositoryInterface" method="deleteById"/>
        <resources>
            <resource ref="Vendor_Module::products"/>
        </resources>
    </route>
    <route url="/V1/orders/:orderId" method="PUT">
        <service class="Vendor\Module\Api\OrderRepositoryInterface" method="update"/>
        <resources>
            <resource ref="Vendor_Module::orders"/>
        </resources>
    </route>
</routes>
